// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  STUDENT
  INSTRUCTOR
  EDITOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  INACTIVE
  PENDING
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum CourseStatus {
  PUBLISHED
  DRAFT
  HIDDEN
  ARCHIVED
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum LessonStatus {
  PUBLISHED
  DRAFT
  HIDDEN
}

enum VideoProvider {
  VIMEO
  MUX
  CLOUDFLARE
  BUNNY
  WISTIA
  AWS_S3
  EXTERNAL
}

enum VideoPrivacyStatus {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MaterialType {
  PDF
  SPREADSHEET
  IMAGE
  LINK
  CHECKLIST
  ARCHIVE
  OTHER
}

enum BillingType {
  ONE_TIME
  MONTHLY
  YEARLY
  FREE
  COURTESY
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum PaymentStatus {
  PENDING
  APPROVED
  REFUSED
  CANCELLED
  REFUNDED
  CHARGEBACK
  EXPIRED
  FAILED
}

enum PaymentGateway {
  MERCADOPAGO
  PAGARME
  ASAAS
  STRIPE
  IUGU
  PAGSEGURO
  MANUAL
}

enum AccessType {
  LIFETIME
  TIMED
  SUBSCRIPTION
  COURTESY
  TRIAL
  MANUAL
  BLOCKED
  CANCELLED
  EXPIRED
}

enum AccessOrigin {
  PURCHASE
  MANUAL
  COURTESY
  FREE_PLAN
  SUBSCRIPTION
  SPECIAL_COUPON
  MIGRATION
}

enum AccessStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

enum CommunityForumStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CommunityTopicStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum CommunityPostStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum CommunityBanStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum CommunityModerationActionType {
  APPROVE_TOPIC
  REJECT_TOPIC
  APPROVE_POST
  REJECT_POST
  PIN_TOPIC
  UNPIN_TOPIC
  LOCK_TOPIC
  UNLOCK_TOPIC
  DELETE_TOPIC
  DELETE_POST
  BAN_USER
  UNBAN_USER
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  phone        String?
  cpf          String?
  passwordHash String?      @map("password_hash")
  googleId     String?      @unique @map("google_id")
  avatarUrl    String?      @map("avatar_url")
  authProvider AuthProvider @default(EMAIL) @map("auth_provider")
  role         UserRole     @default(STUDENT)
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  lastLoginAt  DateTime?    @map("last_login_at")

  orders            Order[]
  payments          Payment[]
  accessPermissions AccessPermission[]
  lessonProgress    LessonProgress[]
  certificates      Certificate[]
  adminLogs         AdminLog[]
  comments          Comment[]
  communityTopics   CommunityTopic[]            @relation("CommunityTopicAuthor")
  approvedCommunityTopics CommunityTopic[]      @relation("CommunityTopicApprovedBy")
  communityPosts    CommunityPost[]             @relation("CommunityPostAuthor")
  approvedCommunityPosts CommunityPost[]        @relation("CommunityPostApprovedBy")
  communityAttachments CommunityAttachment[]    @relation("CommunityAttachmentUploadedBy")
  communityBans     CommunityBan[]              @relation("CommunityBanUser")
  issuedCommunityBans CommunityBan[]            @relation("CommunityBanCreatedBy")
  revokedCommunityBans CommunityBan[]           @relation("CommunityBanRevokedBy")
  communityModerationActions CommunityModerationAction[] @relation("CommunityModerator")
  communityTargetActions CommunityModerationAction[]     @relation("CommunityTargetUser")

  @@map("users")
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  image       String?
  order       Int          @default(0)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  courses Course[]

  @@map("categories")
}

model Platform {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  image       String?
  order       Int          @default(0)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  courses Course[]

  @@map("platforms")
}

model Course {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  shortDescription String?      @map("short_description")
  description      String?
  coverImage       String?      @map("cover_image")
  bannerImage      String?      @map("banner_image")
  price            Decimal?     @db.Decimal(10, 2)
  status           CourseStatus @default(DRAFT)
  categoryId       String?      @map("category_id")
  platformId       String?      @map("platform_id")
  workloadHours    Int?         @map("workload_hours")
  instructorId     String?      @map("instructor_id")
  certificateEnabled Boolean    @default(false) @map("certificate_enabled")
  displayOrder     Int          @default(0) @map("display_order")
  trailColorRgb    String?      @map("trail_color_rgb")
  badgeTextColorRgb String?     @map("badge_text_color_rgb")
  badgeLabel        String?      @map("badge_label")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  category          Category?          @relation(fields: [categoryId], references: [id])
  platform          Platform?          @relation(fields: [platformId], references: [id])
  modules           Module[]
  lessons           Lesson[]
  materials         Material[]
  planCourses       PlanCourse[]
  orderItems        OrderItem[]
  accessPermissions AccessPermission[]
  lessonProgress    LessonProgress[]
  certificates      Certificate[]
  courseCategories  CourseCategory[]

  @@map("courses")
}

model CatalogCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  parentId    String?           @map("parent_id")
  order       Int               @default(0)
  status      EntityStatus      @default(ACTIVE)
  showInMenu  Boolean           @default(true) @map("show_in_menu")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  parent           CatalogCategory?  @relation("CatalogCategoryTree", fields: [parentId], references: [id])
  children         CatalogCategory[] @relation("CatalogCategoryTree")
  courseCategories CourseCategory[]

  @@index([parentId, order])
  @@map("catalog_categories")
}

model CourseCategory {
  courseId    String   @map("course_id")
  categoryId  String   @map("category_id")
  createdAt   DateTime @default(now()) @map("created_at")

  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  category  CatalogCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([courseId, categoryId])
  @@index([categoryId])
  @@map("course_categories")
}

model Module {
  id          String       @id @default(cuid())
  courseId    String       @map("course_id")
  title       String
  description String?
  order       Int          @default(0)
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  materials Material[]

  @@map("modules")
}

model VideoAsset {
  id               String             @id @default(cuid())
  provider         VideoProvider
  providerVideoId  String             @map("provider_video_id")
  title            String?
  description      String?
  playbackUrl      String?            @map("playback_url")
  embedUrl         String?            @map("embed_url")
  thumbnailUrl     String?            @map("thumbnail_url")
  durationSeconds  Int?               @map("duration_seconds")
  privacyStatus    VideoPrivacyStatus @default(PRIVATE) @map("privacy_status")
  downloadAllowed  Boolean            @default(false) @map("download_allowed")
  processingStatus ProcessingStatus   @default(PENDING) @map("processing_status")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  lessons Lesson[]

  @@map("video_assets")
}

model Lesson {
  id                     String              @id @default(cuid())
  courseId               String              @map("course_id")
  moduleId               String?             @map("module_id")
  videoAssetId           String?             @map("video_asset_id")
  title                  String
  description            String?
  videoUrl               String?             @map("video_url")
  videoProvider          VideoProvider?      @map("video_provider")
  videoProviderId        String?             @map("video_provider_id")
  videoEmbedUrl          String?             @map("video_embed_url")
  videoPlaybackUrl       String?             @map("video_playback_url")
  videoThumbnailUrl      String?             @map("video_thumbnail_url")
  videoDurationSeconds   Int?                @map("video_duration_seconds")
  videoPrivacyStatus     VideoPrivacyStatus? @map("video_privacy_status")
  videoDownloadAllowed   Boolean             @default(false) @map("video_download_allowed")
  videoProcessingStatus  ProcessingStatus?   @map("video_processing_status")
  thumbnail              String?
  durationSeconds        Int?                @map("duration_seconds")
  order                  Int                 @default(0)
  isFree                 Boolean             @default(false) @map("is_free")
  searchKeywords         String?             @map("search_keywords")
  previewEnabled         Boolean             @default(false) @map("preview_enabled")
  previewDurationSeconds Int?                @map("preview_duration_seconds")
  previewPercentage      Int?                @map("preview_percentage")
  requiresPlan           Boolean             @default(false) @map("requires_plan")
  requiredPlanId         String?             @map("required_plan_id")
  status                 LessonStatus        @default(DRAFT)
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  course         Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module         Module?         @relation(fields: [moduleId], references: [id])
  videoAsset     VideoAsset?     @relation(fields: [videoAssetId], references: [id])
  requiredPlan   Plan?           @relation("RequiredPlan", fields: [requiredPlanId], references: [id])
  materials      Material[]
  planLessons    PlanLesson[]
  lessonProgress LessonProgress[]
  comments       Comment[]

  @@map("lessons")
}

model Material {
  id          String       @id @default(cuid())
  courseId    String?      @map("course_id")
  moduleId    String?      @map("module_id")
  lessonId    String?      @map("lesson_id")
  title       String
  description String?
  fileUrl     String?      @map("file_url")
  externalUrl String?      @map("external_url")
  type        MaterialType
  isFree      Boolean      @default(false) @map("is_free")
  status      EntityStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  course Course?  @relation(fields: [courseId], references: [id])
  module Module?  @relation(fields: [moduleId], references: [id])
  lesson Lesson?  @relation(fields: [lessonId], references: [id])

  @@map("materials")
}

model Plan {
  id                 String      @id @default(cuid())
  name               String
  slug               String      @unique
  description        String?
  price              Decimal?    @db.Decimal(10, 2)
  annualPrice        Decimal?    @db.Decimal(10, 2) @map("annual_price")
  monthlyPrice       Decimal?    @db.Decimal(10, 2) @map("monthly_price")
  billingType        BillingType @default(ONE_TIME) @map("billing_type")
  accessDurationDays Int?        @map("access_duration_days")
  annualAccessDurationDays Int   @default(365) @map("annual_access_duration_days")
  monthlyAccessDurationDays Int? @map("monthly_access_duration_days")
  monthlyEnabled     Boolean     @default(false) @map("monthly_enabled")
  benefits           String[]    @default([])
  maxInstallments    Int         @default(12) @map("max_installments")
  maxInstallmentsNoInterest Int  @default(1) @map("max_installments_no_interest")
  status             PlanStatus  @default(ACTIVE)
  highlighted        Boolean     @default(false)
  certificateIncluded Boolean    @default(false) @map("certificate_included")
  supportIncluded    Boolean     @default(false) @map("support_included")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  planCourses       PlanCourse[]
  planLessons       PlanLesson[]
  orderItems        OrderItem[]
  accessPermissions AccessPermission[]
  coupons           Coupon[]
  requiredByLessons Lesson[]     @relation("RequiredPlan")

  @@map("plans")
}

model PlanCourse {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([planId, courseId])
  @@map("plan_courses")
}

model PlanLesson {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  lessonId  String   @map("lesson_id")
  createdAt DateTime @default(now()) @map("created_at")

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([planId, lessonId])
  @@map("plan_lessons")
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType @map("discount_type")
  discountValue  Decimal      @db.Decimal(10, 2) @map("discount_value")
  planId         String?      @map("plan_id")
  startsAt       DateTime?    @map("starts_at")
  expiresAt      DateTime?    @map("expires_at")
  maxUses        Int?         @map("max_uses")
  usesCount      Int          @default(0) @map("uses_count")
  maxUsesPerUser Int?         @map("max_uses_per_user")
  status         CouponStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  plan   Plan?   @relation(fields: [planId], references: [id])
  orders Order[]

  @@map("coupons")
}

model Order {
  id               String         @id @default(cuid())
  userId           String         @map("user_id")
  total            Decimal        @db.Decimal(10, 2)
  discountTotal    Decimal        @default(0) @db.Decimal(10, 2) @map("discount_total")
  finalTotal       Decimal        @db.Decimal(10, 2) @map("final_total")
  paymentMethod    PaymentMethod? @map("payment_method")
  paymentStatus    PaymentStatus  @default(PENDING) @map("payment_status")
  gateway          PaymentGateway?
  gatewayReference String?        @map("gateway_reference")
  couponId         String?        @map("coupon_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  coupon     Coupon?     @relation(fields: [couponId], references: [id])
  orderItems OrderItem[]
  payments   Payment[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  courseId  String?  @map("course_id")
  planId    String?  @map("plan_id")
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])
  plan   Plan?   @relation(fields: [planId], references: [id])

  @@map("order_items")
}

model Payment {
  id               String         @id @default(cuid())
  orderId          String         @map("order_id")
  userId           String         @map("user_id")
  gateway          PaymentGateway
  paymentMethod    PaymentMethod  @map("payment_method")
  paymentStatus    PaymentStatus  @default(PENDING) @map("payment_status")
  gatewayPaymentId String?        @map("gateway_payment_id")
  amount           Decimal        @db.Decimal(10, 2)
  installments     Int            @default(1)
  pixQrCode        String?        @map("pix_qr_code")
  pixCopyPaste     String?        @map("pix_copy_paste")
  paidAt           DateTime?      @map("paid_at")
  expiresAt        DateTime?      @map("expires_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("payments")
}

model Comment {
  id          String    @id @default(cuid())
  lessonId    String    @map("lesson_id")
  userId      String    @map("user_id")
  parentId    String?   @map("parent_id")
  content     String
  status      String    @default("APPROVED")
  approvedAt  DateTime? @map("approved_at")
  approvedBy  String?   @map("approved_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([lessonId, status, createdAt])
  @@index([parentId])
  @@map("comments")
}

model PaymentWebhook {
  id          String         @id @default(cuid())
  gateway     PaymentGateway
  eventType   String         @map("event_type")
  payload     Json
  processed   Boolean        @default(false)
  createdAt   DateTime       @default(now()) @map("created_at")
  processedAt DateTime?      @map("processed_at")

  @@map("payment_webhooks")
}

model AccessPermission {
  id         String       @id @default(cuid())
  userId     String       @map("user_id")
  courseId   String?      @map("course_id")
  planId     String?      @map("plan_id")
  accessType AccessType   @map("access_type")
  origin     AccessOrigin
  startsAt   DateTime     @default(now()) @map("starts_at")
  expiresAt  DateTime?    @map("expires_at")
  status     AccessStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  plan   Plan?   @relation(fields: [planId], references: [id])

  @@map("access_permissions")
}

model LessonProgress {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  courseId      String    @map("course_id")
  lessonId      String    @map("lesson_id")
  watchedSeconds Int      @default(0) @map("watched_seconds")
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at")
  lastWatchedAt DateTime? @map("last_watched_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Certificate {
  id              String            @id @default(cuid())
  userId          String            @map("user_id")
  courseId        String            @map("course_id")
  certificateCode String            @unique @map("certificate_code")
  issuedAt        DateTime          @default(now()) @map("issued_at")
  pdfUrl          String?           @map("pdf_url")
  status          CertificateStatus @default(ISSUED)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

model AdminLog {
  id          String   @id @default(cuid())
  adminUserId String   @map("admin_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  description String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser User @relation(fields: [adminUserId], references: [id])

  @@map("admin_logs")
}

model HeroBanner {
  id               String   @id @default(cuid())
  title            String
  subtitle         String?
  badge            String?
  videoUrl         String?  @map("video_url")
  imageUrl         String?  @map("image_url")
  ctaText          String?  @map("cta_text")
  ctaHref          String?  @map("cta_href")
  secondaryCtaText String?  @map("secondary_cta_text")
  secondaryCtaHref String?  @map("secondary_cta_href")
  consoles         String[]
  order            Int      @default(0)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("hero_banners")
}

model LessonSuggestion {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  lesson    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lesson_suggestions")
}

model HelpCategory {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  order       Int          @default(0)
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  articles HelpArticle[]

  @@map("help_categories")
}

model HelpArticle {
  id          String       @id @default(cuid())
  categoryId  String       @map("category_id")
  title       String
  slug        String       @unique
  excerpt     String?
  content     String       @db.Text
  order       Int          @default(0)
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  category HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, order])
  @@map("help_articles")
}

model CommunityForum {
  id                    String               @id @default(cuid())
  name                  String
  slug                  String               @unique
  description           String?              @db.Text
  order                 Int                  @default(0)
  status                CommunityForumStatus @default(ACTIVE)
  topicApprovalRequired Boolean              @default(false) @map("topic_approval_required")
  replyApprovalRequired Boolean              @default(false) @map("reply_approval_required")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  topics                CommunityTopic[]
  moderationActions     CommunityModerationAction[]

  @@index([status, order])
  @@map("community_forums")
}

model CommunityTopic {
  id            String               @id @default(cuid())
  forumId        String               @map("forum_id")
  authorId       String               @map("author_id")
  approvedById   String?              @map("approved_by_id")
  title          String
  slug           String               @unique
  content        String               @db.Text
  status         CommunityTopicStatus @default(PENDING)
  isPinned       Boolean              @default(false) @map("is_pinned")
  isLocked       Boolean              @default(false) @map("is_locked")
  viewsCount     Int                  @default(0) @map("views_count")
  repliesCount   Int                  @default(0) @map("replies_count")
  lastReplyAt    DateTime?            @map("last_reply_at")
  approvedAt     DateTime?            @map("approved_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  forum          CommunityForum       @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author         User                 @relation("CommunityTopicAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approvedBy     User?                @relation("CommunityTopicApprovedBy", fields: [approvedById], references: [id])
  posts          CommunityPost[]
  attachments    CommunityAttachment[]
  moderationActions CommunityModerationAction[]

  @@index([forumId, status, isPinned, lastReplyAt])
  @@index([authorId, createdAt])
  @@map("community_topics")
}

model CommunityPost {
  id            String              @id @default(cuid())
  topicId        String              @map("topic_id")
  authorId       String              @map("author_id")
  approvedById   String?             @map("approved_by_id")
  parentPostId   String?             @map("parent_post_id")
  content        String              @db.Text
  status         CommunityPostStatus @default(PENDING)
  approvedAt     DateTime?           @map("approved_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  topic          CommunityTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author         User                @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approvedBy     User?               @relation("CommunityPostApprovedBy", fields: [approvedById], references: [id])
  parentPost     CommunityPost?      @relation("CommunityPostReplies", fields: [parentPostId], references: [id], onDelete: Cascade)
  replies        CommunityPost[]     @relation("CommunityPostReplies")
  attachments    CommunityAttachment[]
  moderationActions CommunityModerationAction[]

  @@index([topicId, status, createdAt])
  @@index([parentPostId])
  @@index([authorId, createdAt])
  @@map("community_posts")
}

model CommunityAttachment {
  id           String           @id @default(cuid())
  topicId       String?          @map("topic_id")
  postId        String?          @map("post_id")
  uploadedById  String           @map("uploaded_by_id")
  fileName      String           @map("file_name")
  fileUrl       String           @map("file_url")
  mimeType      String?          @map("mime_type")
  sizeBytes     Int?             @map("size_bytes")
  createdAt     DateTime         @default(now()) @map("created_at")

  topic         CommunityTopic?  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  post          CommunityPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  uploadedBy    User             @relation("CommunityAttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([postId])
  @@index([uploadedById, createdAt])
  @@map("community_attachments")
}

model CommunityBan {
  id           String             @id @default(cuid())
  userId        String             @map("user_id")
  createdById   String             @map("created_by_id")
  revokedById   String?            @map("revoked_by_id")
  reason        String?            @db.Text
  status        CommunityBanStatus @default(ACTIVE)
  startsAt      DateTime           @default(now()) @map("starts_at")
  endsAt        DateTime?          @map("ends_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  user          User               @relation("CommunityBanUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy     User               @relation("CommunityBanCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  revokedBy     User?              @relation("CommunityBanRevokedBy", fields: [revokedById], references: [id])

  @@index([userId, status, endsAt])
  @@map("community_bans")
}

model CommunityModerationAction {
  id           String                        @id @default(cuid())
  moderatorId   String                        @map("moderator_id")
  targetUserId  String?                       @map("target_user_id")
  forumId       String?                       @map("forum_id")
  topicId       String?                       @map("topic_id")
  postId        String?                       @map("post_id")
  actionType    CommunityModerationActionType @map("action_type")
  reason        String?                       @db.Text
  createdAt     DateTime                      @default(now()) @map("created_at")

  moderator     User                          @relation("CommunityModerator", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetUser    User?                         @relation("CommunityTargetUser", fields: [targetUserId], references: [id])
  forum         CommunityForum?               @relation(fields: [forumId], references: [id], onDelete: Cascade)
  topic         CommunityTopic?               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  post          CommunityPost?                @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([moderatorId, createdAt])
  @@index([topicId])
  @@index([postId])
  @@map("community_moderation_actions")
}
