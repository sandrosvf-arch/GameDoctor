# =============================================================
# GameDoctor — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================

# -------------------------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gamedoctor?schema=public"

# -------------------------------------------------------------
# NEXTAUTH / AUTH.JS v5
# -------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# -------------------------------------------------------------
# GOOGLE OAUTH
# https://console.cloud.google.com/
# -------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------------------------------------------------------------
# EMAIL (Nodemailer — use SMTP, Resend, SendGrid, etc.)
# -------------------------------------------------------------
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@gamedoctor.com.br"

# -------------------------------------------------------------
# VIDEO PROVIDERS — configure only the one you use
# -------------------------------------------------------------

# Vimeo
VIMEO_ACCESS_TOKEN=""
VIMEO_CLIENT_ID=""
VIMEO_CLIENT_SECRET=""

# Mux
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_STREAM_SIGNING_KEY_ID=""
CLOUDFLARE_STREAM_SIGNING_KEY=""

# Bunny Stream
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_PULL_ZONE=""
BUNNY_STREAM_SIGNING_KEY=""

# Wistia
WISTIA_API_PASSWORD=""
WISTIA_PROJECT_ID=""

# AWS S3 + CloudFront
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_DISTRIBUTION_ID=""
AWS_CLOUDFRONT_DOMAIN=""
AWS_CLOUDFRONT_KEY_PAIR_ID=""
# Path to private key file or base64 encoded key
AWS_CLOUDFRONT_PRIVATE_KEY=""

# -------------------------------------------------------------
# PAYMENT GATEWAYS — configure only the one you use
# -------------------------------------------------------------

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Pagar.me
PAGARME_API_KEY=""
PAGARME_WEBHOOK_SECRET=""

# Asaas
ASAAS_API_KEY=""
ASAAS_WEBHOOK_SECRET=""
# sandbox or production
ASAAS_ENVIRONMENT="sandbox"

# Stripe
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Iugu
IUGU_API_KEY=""
IUGU_WEBHOOK_SECRET=""

# PagSeguro
PAGSEGURO_EMAIL=""
PAGSEGURO_TOKEN=""
PAGSEGURO_WEBHOOK_SECRET=""

# -------------------------------------------------------------
# APP PUBLIC VARS (exposed to browser — no secrets!)
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GameDoctor"
# Domain where video embeds are allowed
NEXT_PUBLIC_EMBED_DOMAIN="gamedoctor.com.br"
# Active video provider: VIMEO | MUX | CLOUDFLARE | BUNNY | WISTIA | AWS_S3 | EXTERNAL
NEXT_PUBLIC_VIDEO_PROVIDER="EXTERNAL"
# Active payment gateway: MERCADOPAGO | PAGARME | ASAAS | STRIPE | IUGU | PAGSEGURO
NEXT_PUBLIC_PAYMENT_GATEWAY="MERCADOPAGO"
